rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwnerEmail() {
      return isAuthenticated() && request.auth.token.email == "Gaston@mimartextiles.com";
    }

    function isSeller() {
      return isAuthenticated();
    }

    match /products/{allPaths=**} {
      allow read: if true;
      allow write, delete: if isOwnerEmail() || isSeller();
    }
  }
}
